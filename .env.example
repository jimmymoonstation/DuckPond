# ── Required ──────────────────────────────────────────────────────────────────

# Brave Search API (free tier: 2,000 req/month) — https://brave.com/search/api/
BRAVE_API_KEY=

# SQLite database path
DATABASE_URL=sqlite:////opt/job-hunt-partner/jobs.db

# Discord bot token — https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Discord channel ID where job alerts + coaching messages are posted
JOB_HUNT_CHANNEL_ID=

# Gmail address and app password for inbox sync
# App password: https://myaccount.google.com/apppasswords (requires 2FA)
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# ── Optional ──────────────────────────────────────────────────────────────────

# Webshare residential proxy — used as DDG fallback when direct is rate-limited
# Format: http://user:pass@p.webshare.io:10000/
WEB_SEARCH_PROXY=

# Webshare API key — enables live bandwidth stats in the dashboard
WEBSHARE_API_KEY=

# Google Calendar OAuth — enables interview sync from calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic API key — only needed for Discord bot coaching (optional)
# The browser extension analyze feature uses the claudebot Claude Code session instead
# WARNING: if set, Claude Code subprocesses will bill against this key
ANTHROPIC_API_KEY=

# Anthropic Admin key — enables live token usage stats in the dashboard
ANTHROPIC_ADMIN_KEY=
